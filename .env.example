# Preferred (server-only, NOT exposed to the browser)
GOOGLE_SHEETS_API_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_RANGE=vendas_nuvemshop

# Fallback names also accepted by the API route (these ARE exposed to the
# browser bundle due to the NEXT_PUBLIC_ prefix — avoid for secret API keys).
# NEXT_PUBLIC_GOOGLE_SHEETS_API_KEY=
# NEXT_PUBLIC_SPREADSHEET_ID=
# NEXT_PUBLIC_SHEET_NAME=vendas_nuvemshop
